<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: Nomor Meja (Full Width dengan Radius Atas) -->
        <LinearLayout
            android:id="@+id/layoutChefHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/orange_nav"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTableName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Meja 1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnDrop"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/img_14"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Konten: List Pesanan & Tombol (Diberi Padding) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/w"
            android:padding="16dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrderItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#EEEEEE" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Tertunda"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Tombol Update Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPending"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="Tunda"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="#757575" />

                <Button
                    android:id="@+id/btnCooking"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    app:backgroundTint="@color/a"
                    android:text="Masak"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="8dp" />

                <Button
                    android:id="@+id/btnReady"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    app:backgroundTint="#935c00"
                    android:text="Siap"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>